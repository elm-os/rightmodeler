{
  "name": "rightmodeler",
  "private": true,
  "description": "Replay real agent traces through cheaper models to prove which swaps are safe.",
  "homepage": "https://rightmodeler.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elm-os/rightmodeler.git"
  },
  "keywords": [
    "ai-agents",
    "agent-evals",
    "cost-optimization",
    "llm-evals",
    "model-routing",
    "traces"
  ],
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format && prettier --write .",
    "check": "turbo run check",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.5"
  }
}
