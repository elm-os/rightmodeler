# OpenRouter API key. Only one provider setup is needed.
OPENROUTER_API_KEY=
# Vercel AI Gateway API key.
AI_GATEWAY_API_KEY=
# LiteLLM proxy base URL.
LITELLM_PROXY_API_BASE=
# LiteLLM proxy virtual key.
LITELLM_PROXY_API_KEY=
# Optional provider selection: openrouter, vercel-ai-gateway, or litellm.
RIGHTMODELER_PROVIDER=
