{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rightmodeler.dev/schemas/task-family-summary.schema.json",
  "title": "Task Family Summary",
  "type": "object",
  "required": ["version", "bundle_id", "task_families"],
  "properties": {
    "version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "task_families": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "run_count",
          "current_models",
          "success_rate",
          "evidence_types"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "run_count": {
            "type": "integer",
            "minimum": 0
          },
          "current_models": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "success_rate": {
            "type": ["number", "null"]
          },
          "evidence_types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
