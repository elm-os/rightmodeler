{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rightmodeler.com/schemas/corpus-manifest.schema.json",
  "title": "Corpus Manifest",
  "$defs": {
    "case": {
      "type": "object",
      "required": [
        "case_id",
        "source_run_id",
        "pipeline_family",
        "workload_label",
        "split",
        "risk",
        "required_evidence",
        "checks"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 1 },
        "source_run_id": { "type": "string", "minLength": 1 },
        "pipeline_family": {
          "type": "string",
          "enum": [
            "reference-freeform",
            "structured-check",
            "tool-trajectory",
            "repo-fix"
          ]
        },
        "workload_label": { "type": "string", "minLength": 1 },
        "split": { "type": "string", "enum": ["working", "holdout"] },
        "risk": { "type": "string", "enum": ["normal", "high"] },
        "required_evidence": {
          "type": "string",
          "enum": ["deterministic", "reference", "trajectory", "abstain"]
        },
        "checks": { "type": "object" },
        "labels": {
          "type": "object",
          "required": ["recommendation", "required_abstention"],
          "properties": {
            "recommendation": {
              "type": "string",
              "enum": ["safe", "unsafe", "not_applicable"]
            },
            "required_abstention": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": [
    "version",
    "corpus_id",
    "corpus_version",
    "parent_version",
    "source_bundle_id",
    "content_digest",
    "cases"
  ],
  "properties": {
    "version": { "type": "string" },
    "corpus_id": { "type": "string", "minLength": 1 },
    "corpus_version": { "type": "string", "minLength": 1 },
    "parent_version": { "type": ["string", "null"] },
    "source_bundle_id": { "type": "string", "minLength": 1 },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "additionalProperties": false
}
