{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rightmodeler.com/schemas/candidate-results.schema.json",
  "title": "Candidate Results",
  "type": "object",
  "$defs": {
    "trajectory": {
      "type": "object",
      "required": ["tool_calls", "terminal_state", "final_output"],
      "properties": {
        "tool_calls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "call_id",
              "tool_name",
              "arguments",
              "attempt",
              "status"
            ],
            "properties": {
              "call_id": { "type": "string", "minLength": 1 },
              "tool_name": { "type": "string", "minLength": 1 },
              "arguments": { "type": "object" },
              "attempt": { "type": "integer", "minimum": 1 },
              "status": { "type": "string", "enum": ["success", "error"] },
              "loop_id": { "type": "string", "minLength": 1 },
              "iteration": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "terminal_state": {
          "type": "string",
          "enum": ["success", "failure", "abstain"]
        },
        "final_output": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "bundle_id",
    "corpus_version_id",
    "candidate",
    "results"
  ],
  "properties": {
    "version": { "type": "string" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "corpus_version_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "candidate": {
      "type": "object",
      "required": ["id", "model", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["imported"] }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "output_text", "cost_usd", "evidence_refs"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "output_text": { "type": "string" },
          "cost_usd": { "type": "number", "minimum": 0 },
          "duration_ms": { "type": ["number", "null"], "minimum": 0 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "trajectory": { "$ref": "#/$defs/trajectory" },
          "reference": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "refs", "verdict", "agreement"],
                "properties": {
                  "type": { "const": "frozen-human-verdict" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "verdict": { "enum": ["pass", "fail", null] },
                  "agreement": {
                    "type": "string",
                    "enum": ["unanimous", "disputed"]
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type", "refs"],
                "properties": {
                  "type": { "const": "reference-evidence" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type", "refs", "trajectory"],
                "properties": {
                  "type": { "const": "reference-trajectory" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "trajectory": { "$ref": "#/$defs/trajectory" }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
