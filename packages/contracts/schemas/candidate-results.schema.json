{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rightmodeler.com/schemas/candidate-results.schema.json",
  "title": "Candidate Results",
  "type": "object",
  "$defs": {
    "replay": {
      "type": "object",
      "required": [
        "mode",
        "max_cost_usd",
        "projected_cost_usd",
        "actual_cost_usd",
        "remaining_cost_usd",
        "cache_hits",
        "cache_misses",
        "status",
        "partial"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["single-shot", "e2e", "mixed"]
        },
        "max_cost_usd": { "type": "number", "exclusiveMinimum": 0 },
        "projected_cost_usd": { "type": "number", "minimum": 0 },
        "actual_cost_usd": { "type": "number", "minimum": 0 },
        "remaining_cost_usd": { "type": "number", "minimum": 0 },
        "cache_hits": { "type": "integer", "minimum": 0 },
        "cache_misses": { "type": "integer", "minimum": 0 },
        "status": {
          "type": "string",
          "enum": ["completed", "budget_exhausted", "failed"]
        },
        "partial": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "trajectory": {
      "type": "object",
      "required": ["tool_calls", "terminal_state", "final_output"],
      "properties": {
        "tool_calls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "call_id",
              "tool_name",
              "arguments",
              "attempt",
              "status"
            ],
            "properties": {
              "call_id": { "type": "string", "minLength": 1 },
              "tool_name": { "type": "string", "minLength": 1 },
              "arguments": { "type": "object" },
              "attempt": { "type": "integer", "minimum": 1 },
              "status": { "type": "string", "enum": ["success", "error"] },
              "loop_id": { "type": "string", "minLength": 1 },
              "iteration": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        },
        "terminal_state": {
          "type": "string",
          "enum": ["success", "failure", "abstain"]
        },
        "final_output": { "type": "string" }
      },
      "additionalProperties": false
    },
    "repo_fix": {
      "type": "object",
      "required": [
        "repository",
        "patch",
        "affected_files",
        "validation_commands"
      ],
      "properties": {
        "repository": {
          "type": "object",
          "required": ["revision"],
          "properties": {
            "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
          },
          "additionalProperties": false
        },
        "patch": { "type": "string", "minLength": 1 },
        "affected_files": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "validation_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "command", "timeout_seconds"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "command": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1,
                "maximum": 300
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "bundle_id",
    "corpus_version_id",
    "candidate",
    "results"
  ],
  "properties": {
    "version": { "type": "string" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "corpus_version_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "candidate": {
      "type": "object",
      "required": ["id", "model", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["imported", "replayed"] }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "output_text", "cost_usd", "evidence_refs"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "output_text": { "type": "string" },
          "cost_usd": { "type": "number", "minimum": 0 },
          "duration_ms": { "type": ["number", "null"], "minimum": 0 },
          "baseline_duration_ms": { "type": ["number", "null"], "minimum": 0 },
          "replay_error": { "type": ["string", "null"] },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "trajectory": { "$ref": "#/$defs/trajectory" },
          "repo_fix": { "$ref": "#/$defs/repo_fix" },
          "reference": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type", "refs", "verdict", "agreement"],
                "properties": {
                  "type": { "const": "frozen-human-verdict" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "verdict": { "enum": ["pass", "fail", null] },
                  "agreement": {
                    "type": "string",
                    "enum": ["unanimous", "disputed"]
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type", "refs"],
                "properties": {
                  "type": { "const": "reference-evidence" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type", "refs", "trajectory"],
                "properties": {
                  "type": { "const": "reference-trajectory" },
                  "refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "trajectory": { "$ref": "#/$defs/trajectory" }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "replay": { "$ref": "#/$defs/replay" }
  },
  "additionalProperties": false
}
