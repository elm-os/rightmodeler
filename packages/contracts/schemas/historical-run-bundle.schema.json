{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rightmodeler.dev/schemas/historical-run-bundle.schema.json",
  "title": "Historical Run Bundle",
  "type": "object",
  "required": ["version", "bundle_id", "runs"],
  "properties": {
    "version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "prompt", "model"],
        "properties": {
          "id": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "system_prompt": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "final_output": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "cost_usd": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
